JWT_SECRET=your-very-secure-secret-key-here
PORT=3000
DB_PATH=/app/data/tabletto.db
NODE_ENV=production

# Restrict CORS in production to the exact frontend origin
# FRONTEND_ORIGIN=https://tabletto.example.org
# Set only behind a known reverse proxy, for example: TRUST_PROXY=1
# TRUST_PROXY=1

# Stock Scheduler Configuration
# Scheduler runs every 5 minutes to check user-specific medication times
ENABLE_STOCK_SCHEDULER=true
STOCK_SCHEDULER_CRON=*/5 * * * *
TZ=Europe/Berlin

# Uploads
UPLOADS_PATH=/app/data/uploads

# Data repair script only (backend/scripts/fix-stock-corruption.js)
# FIX_OPTION=a
